# Neon Postgres connection string
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Greenfield setup (Vercel + Neon + Mac worker): see DEPLOY.md

# Shared secret for Mac mini worker → CRM API auth
WORKER_API_KEY=generate_a_long_random_string_here

# Admin suite login (defaults to WORKER_API_KEY if unset)
ADMIN_PASSWORD=your_admin_password_here

# Apollo.io — required for Enrich button on Jobs / Companies (add to Vercel too)
APOLLO_API_KEY=

# ContactOut API — personal email/mobile via LinkedIn (worker + Vercel Enrich button)
CONTACTOUT_API_KEY=

# SerpApi — Google Jobs API (JobSpy Google scraper is broken / unused).
# Key belongs on the Mac worker (`~/.vsearch/worker.env`). Google runs on the
# 5 AM scrape by default (weekday schedule gate); leave bypass unset in prod.
# https://serpapi.com/manage-api-key
# SERPAPI_API_KEY=
# SERPAPI_GOOGLE_MAX_PAGES=3
# SERPAPI_GOOGLE_ENABLED=1

# Public app URL (canonical CRM host — never legacy v-executive-search.vercel.app)
NEXT_PUBLIC_APP_URL=https://v-executive-search-delta.vercel.app

# Resend.com for daily email reports (optional on Vercel; required on worker)
RESEND_API_KEY=

# Demo request form on the marketing landing page (defaults to tech@vexecutivesearch.com)
# Requires RESEND_API_KEY on Vercel for delivery (otherwise the form falls back to mailto).
# DEMO_REQUEST_EMAIL=tech@vexecutivesearch.com

# Anthropic Haiku — call openers + activity summaries
ANTHROPIC_API_KEY=
# OPENER_MODEL=claude-3-5-haiku-20241022
# OPENER_MAX_PER_RUN=25

# Vercel Cron auth for /api/cron/check-worker (auto-set on Vercel when crons are enabled)
CRON_SECRET=
