# Neon Postgres connection string
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Shared secret for Mac mini worker → CRM API auth
WORKER_API_KEY=generate_a_long_random_string_here

# Admin suite login (defaults to WORKER_API_KEY if unset)
ADMIN_PASSWORD=your_admin_password_here

# Resend.com for daily email reports (optional on Vercel; required on worker)
RESEND_API_KEY=
