# ContactOut dashboard automation (Playwright folder only — NOT used by production worker)

CONTACTOUT_MODE=dashboard
CONTACTOUT_API_KEY=

# Stealth browser engine: patchright | playwright | camoufox
CONTACTOUT_BROWSER_ENGINE=patchright

# Prefer headed browsers (recommended for login + Turnstile)
CONTACTOUT_HEADLESS=false

# Session + profile (absolute paths recommended for launchd)
CONTACTOUT_SESSION_FILE=/absolute/path/to/Playwright/.contactout-session.json
CONTACTOUT_CHROME_PROFILE=/absolute/path/to/Playwright/.contactout-chrome-profile

# Human pacing between dashboard lookups (seconds)
CONTACTOUT_DASHBOARD_DELAY_MIN=60
CONTACTOUT_DASHBOARD_DELAY_MAX=150
CONTACTOUT_HUMAN_DELAY_MIN_MS=3000
CONTACTOUT_HUMAN_DELAY_MAX_MS=7000

# 429 / rate-limit cooldown (seconds) — exponential backoff also applies
CONTACTOUT_RATE_LIMIT_COOLDOWN=3600

# Credit guardian: when UI balance can't be read, assume this many credits (0 = fail closed)
CONTACTOUT_ASSUME_CREDITS=999

# Rotating residential proxy (single URL or comma-separated pool)
# CONTACTOUT_PROXY_URL=http://user:pass@gate.residential:port
# CONTACTOUT_PROXY_LIST=http://a:port,http://b:port

# CDP fingerprint alignment (timezone/locale should match proxy geography)
CONTACTOUT_CDP_TIMEZONE=America/New_York
CONTACTOUT_CDP_LOCALE=en-US

# macOS Keychain auto re-login
CONTACTOUT_KEYCHAIN_ACCOUNT=your-contactout-login@company.com
CONTACTOUT_KEYCHAIN_SERVICE=v-execsearch-contactout

# Optional IMAP OTP
# CONTACTOUT_OTP_IMAP_HOST=imap.gmail.com
# CONTACTOUT_OTP_IMAP_USER=hello@example.com
# CONTACTOUT_OTP_IMAP_PASSWORD=app-password

# CRM sync (optional — contactout_dashboard_sync.py)
CRM_API_URL=https://your-app.vercel.app
CRM_API_KEY=

ALERT_EMAIL=hello@example.com
RESEND_API_KEY=
REPORT_FROM_EMAIL=
CONTACTOUT_ALERT_COOLDOWN_HOURS=6
