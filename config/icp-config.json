{
  "$comment": "ICP scoring config — hot-editable, version-controlled. Every filter is an independent flag; the scoring formula ignores disabled inputs entirely. Flags marked safe are deterministic (exact name / .gov) and annotation-only until the view's hide toggles are used.",
  "flags": {
    "exclude_fortune_lists": true,
    "exclude_gov_domains": true,
    "exclude_known_staffing_agencies": true,
    "exclude_known_large_private": true,
    "deprioritize_gov_school_patterns": true,
    "deprioritize_hospital_retail_patterns": true,
    "deprioritize_large_company_estimate": true,
    "role_type_scoring_enabled": true,
    "comp_scoring_enabled": true,
    "comp_estimate_enabled": true,
    "icp_multiplier_enabled": true
  },
  "score_weights": {
    "role_type_bonus": {
      "leadership": 15,
      "management": 10,
      "professional": 10,
      "specialized": 10,
      "support": -5,
      "hourly": -10,
      "unknown": 0
    },
    "private_bonus": 10,
    "size_penalty_large": -35,
    "comp_penalty_below_min": -5,
    "comp_estimate_adjustment_max": 5,
    "pattern_deprioritize_penalty": -10,
    "multiplier_base": 0.2,
    "multiplier_span": 0.8,
    "fit_weights": {
      "private": 0.25,
      "size": 0.35,
      "role": 0.15,
      "urgency": 0.15,
      "ta": 0.1
    }
  },
  "thresholds": {
    "comp_min_annual": 50000,
    "comp_min_hourly": 25,
    "hourly_annualize_factor": 2080,
    "keep_confidence": 0.9,
    "role_ambiguity_confidence": 0.7,
    "size_band_micro_max": 24,
    "size_band_small_max": 99,
    "size_band_mid_max": 750,
    "size_band_exclude_above": 2500
  },
  "role_types": {
    "leadership": {
      "patterns": [
        "\\b(vp|vice president|chief|c[efotm]o|chro|head of|president|managing director|executive director|partner)\\b",
        "\\bdirector\\b"
      ],
      "exclude_overrides": [
        "director of first impressions",
        "director of fun",
        "funeral director",
        "activities director",
        "activity director"
      ]
    },
    "management": {
      "patterns": [
        "\\b(manager|supervisor|superintendent|team lead|lead of)\\b"
      ],
      "exclude_overrides": []
    },
    "professional": {
      "patterns": [
        "\\b(accountant|paralegal|attorney|lawyer|counsel|hr generalist|human resources|marketing|buyer|planner|estimator|underwriter|adjuster|consultant|administrator|coordinator|recruiter|auditor|bookkeeping manager)\\b"
      ],
      "exclude_overrides": []
    },
    "specialized": {
      "patterns": [
        "\\b(engineer|architect|controller|actuary|analyst|scientist|developer|nurse practitioner|physician|dentist|pharmacist|veterinarian|therapist|surveyor)\\b"
      ],
      "exclude_overrides": []
    },
    "support": {
      "patterns": [
        "\\b(assistant|receptionist|front desk|clerk|secretary|dispatcher|office support)\\b"
      ],
      "exclude_overrides": [
        "executive assistant"
      ]
    },
    "hourly": {
      "patterns": [
        "\\b(cashier|driver|barista|server|bartender|warehouse|janitor|custodian|housekeeper|housekeeping|dishwasher|cook|line cook|crew|laborer|landscaper|stocker|delivery|valet|host|hostess|busser|porter|cleaner|maid|groomer|technician|mechanic|installer|mover|packer|picker|sales associate|team member|retail associate|caregiver|aide|attendant|security guard|guard)\\b"
      ],
      "exclude_overrides": []
    }
  },
