# Apollo.io API key — https://docs.apollo.io/docs/create-api-key
APOLLO_API_KEY=your_apollo_api_key_here

# ContactOut — auto mode (default): API first, dashboard fallback on Mac when no key or phone credits out
# CONTACTOUT_MODE=auto|api|dashboard
CONTACTOUT_MODE=auto
CONTACTOUT_API_KEY=your_contactout_api_token_here

# Dashboard mode only (after running scripts/contactout_login.py once):
# CONTACTOUT_BROWSER_PROFILE=worker/.contactout-browser
# CONTACTOUT_HEADLESS=true
# CONTACTOUT_DASHBOARD_DELAY_MIN=60
# CONTACTOUT_DASHBOARD_DELAY_MAX=150

CRM_API_URL=https://your-crm.vercel.app
CRM_API_KEY=your_worker_api_key_here
ALERT_EMAIL=hello@proventheory.co

# Daily report email via Resend (https://resend.com)
RESEND_API_KEY=re_xxxxxxxx
REPORT_FROM_EMAIL=reports@yourdomain.com
