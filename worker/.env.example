# Worker environment — lives on the Mac that runs launchd (usually Mac mini).
# Greenfield / new machine / MacBook vs mini: see ../DEPLOY.md
#
# Apollo.io API key — https://docs.apollo.io/docs/create-api-key
APOLLO_API_KEY=your_apollo_api_key_here

# ContactOut — auto mode (default): API first, dashboard fallback on Mac when no key or phone credits out
# CONTACTOUT_MODE=auto|api|dashboard
CONTACTOUT_MODE=auto
CONTACTOUT_API_KEY=your_contactout_api_token_here

# ContactOut dashboard (Mac worker only — see DEPLOY.md)
# Use absolute paths on the machine that runs launchd:
# CONTACTOUT_SESSION_FILE=/Users/worker-user/path/to/repo/worker/.contactout-session.json
# CONTACTOUT_KEYCHAIN_ACCOUNT=contactout-login@company.com   # ContactOut email, NOT macOS username
# CONTACTOUT_HEADLESS=true

# Layer 2 auto re-login (macOS Keychain — run scripts/contactout_store_credentials.py once):
# CONTACTOUT_KEYCHAIN_ACCOUNT=you@company.com
# CONTACTOUT_KEYCHAIN_SERVICE=v-execsearch-contactout

# Optional Layer 2 OTP via IMAP (hello@proventheory.co inbox):
# CONTACTOUT_OTP_IMAP_HOST=imap.gmail.com
# CONTACTOUT_OTP_IMAP_USER=hello@proventheory.co
# CONTACTOUT_OTP_IMAP_PASSWORD=app-specific-password
# CONTACTOUT_OTP_FROM_FILTER=contactout
# CONTACTOUT_DASHBOARD_DELAY_MIN=60
# CONTACTOUT_DASHBOARD_DELAY_MAX=150

CRM_API_URL=https://your-crm.vercel.app
CRM_API_KEY=your_worker_api_key_here
ALERT_EMAIL=hello@proventheory.co

# Daily report email via Resend (https://resend.com)
RESEND_API_KEY=re_xxxxxxxx
REPORT_FROM_EMAIL=reports@yourdomain.com
