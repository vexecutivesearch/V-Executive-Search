# Worker environment — lives on the Mac that runs launchd (usually Mac mini).
# Greenfield / new machine: see ../DEPLOY.md
#
# Apollo.io API key — https://docs.apollo.io/docs/create-api-key
APOLLO_API_KEY=your_apollo_api_key_here

# ContactOut API — personal email/mobile via LinkedIn URL (no browser automation)
CONTACTOUT_API_KEY=your_contactout_api_token_here
# API-only by default. Browser/dashboard fallback must be explicitly enabled
# after Phase 1 evidence and paid-egress review.
CONTACTOUT_MODE=api
# ENABLE_CONTACTOUT_HYBRID=true
# CONTACTOUT_RATE_LIMIT_COOLDOWN=3600   # seconds to pause after HTTP 429

# SerpApi — Google Jobs API. When set, the scrape auto-enables the Google board
# via SerpApi (JobSpy Google is not used). ~10 results/page.
# https://serpapi.com/manage-api-key
# SERPAPI_API_KEY=your_serpapi_key_here
# SERPAPI_GOOGLE_ENABLED=1
#
# SerpApi metering + caps (worker env overrides CRM pipeline-config `serpapi`
# block; all knobs config-driven). The meter file survives release swaps.
# SERPAPI_MONTHLY_PLAN=15000        # plan searches/month
# SERPAPI_BUDGET_PCT=0.8            # budget guard: skip Google past plan*pct
# SERPAPI_RENEWAL_DAY=11            # plan renewal day (month counter resets)
# SERPAPI_RUN_CAP=200               # hard per-run search cap (loop-bug fuse)
# SERPAPI_USAGE_FILE=~/.vsearch/serpapi_usage.json
#
# Marginal-yield pagination (NOT a fixed page cap — pages continue while the
# per-page net-new ratio earns it; ceilings are runaway circuit breakers).
# GOOGLE_PAGE_MIN_YIELD=0.3         # continue while new_ratio >= this
# GOOGLE_MAX_PAGES=5                # steady-state circuit breaker
# GOOGLE_MAX_PAGES_COLD=10          # cold-market ceiling (day-one depth)
# GOOGLE_COLD_MARKET_DAYS=7         # market unscraped > N days = cold
#
# Per-board schedule gate — Google scrapes the 6 AM run, weekdays only; the
# pipeline itself still runs 6 AM AND 6 PM daily (Indeed/LinkedIn untouched).
# GOOGLE_BOARD_RUNS=am              # csv, e.g. "am,pm"
# GOOGLE_BOARD_DAYS=weekdays        # "weekdays" | "all"
# SERPAPI_SCHEDULE_GATE_BYPASS=1    # escape hatch: force Google this run
#
# Adaptive title frequency — titles with zero net-new companies in a market
# for N consecutive runs drop to every-interval-days there; any net-new
# result promotes them back to daily. Disable to revert to daily everywhere.
# GOOGLE_ADAPTIVE_ENABLED=true
# GOOGLE_ADAPTIVE_EMPTY_RUNS=3
# GOOGLE_ADAPTIVE_INTERVAL_DAYS=2
# GOOGLE_TITLE_STATS_FILE=~/.vsearch/google_title_stats.json

CRM_API_URL=https://your-crm.vercel.app
CRM_API_KEY=your_worker_api_key_here
ALERT_EMAIL=hello@proventheory.co

# Optional controlled code sync before scheduled/admin-triggered runs.
# Advance origin/worker-production only after tests, DB push, Vercel deploy,
# and smoke checks pass. Do not point this at raw origin/main.
# WORKER_SELF_SYNC_ENABLED=true
# WORKER_RELEASE_REF=origin/worker-production
# WORKER_RELEASE_CHECKOUT=/Users/vsearch/Projects/V-Executive-Search-release
# Canonical worker env lives outside edit/release checkouts. After bootstrap,
# update this file, not a checkout-local worker/.env.
# WORKER_ENV_FILE=/Users/vsearch/.vsearch/worker.env
# WORKER_RUNTIME_ENV_FILE=/Users/vsearch/.vsearch/worker.env
# Optional rollback checkout retained during release swaps.
# WORKER_PREVIOUS_RELEASE_CHECKOUT=/Users/vsearch/Projects/V-Executive-Search-release-previous
# Optional: Python used to create release checkout .venv.
# WORKER_BOOTSTRAP_PYTHON=/opt/homebrew/bin/python3

# Daily report email via Resend (https://resend.com)
RESEND_API_KEY=re_xxxxxxxx
REPORT_FROM_EMAIL=reports@yourdomain.com

# Outreach sequencer — reply ingestion (IMAP poll of the Reply-To mailbox).
# The poll launchd agent pumps texts + inbound every 5 minutes.
# OUTREACH_IMAP_HOST=imap.gmail.com
# OUTREACH_IMAP_USER=replies@yourdomain.com
# OUTREACH_IMAP_PASSWORD=app_password_here
# OUTREACH_IMAP_FOLDER=INBOX
# OUTREACH_IMAP_PORT=993
# OUTREACH_IMESSAGE_DELAY=4          # seconds between AppleScript sends
# OUTREACH_STATE_FILE=~/.vsearch/outreach_state.json

# Anthropic — Haiku call openers + call transcript summaries
ANTHROPIC_API_KEY=
# OPENER_MODEL=claude-3-5-haiku-20241022
# OPENER_MAX_PER_RUN=25

# LinkedIn job poster crawl (Meet the hiring team / job poster on public job pages)
LINKEDIN_FETCH_HIRING_TEAM=true
# Draws per LinkedIn search — union + dedupe mitigates JobSpy paginator variance (default 3)
# LINKEDIN_DRAW_COUNT=3
# Pause between draws (seconds) — tune down to 2 draws if draw 3 rarely adds rows
# LINKEDIN_DRAW_JITTER_MIN=4
# LINKEDIN_DRAW_JITTER_MAX=12
# Optional: li_at cookie — DISABLED by default (ban risk on 2× daily automated runs).
# Only enable with a BURNER LinkedIn account after measuring uplift on 5 jobs.
# LINKEDIN_LI_AT_ENABLED=true
# LINKEDIN_LI_AT=your_burner_li_at_cookie
# LINKEDIN_POSTER_DELAY_MIN=2
# LINKEDIN_POSTER_DELAY_MAX=4
